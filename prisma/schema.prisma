// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  cart          Cart?
  profiles      ProfilKesehatan[]
  pesanan       Pesanan[]

  role       String?
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum StatusPesanan {
  DIPROSES
  DIKIRIM
  SELESAI
}

enum StatusPembayaran {
  BERHASIL
  GAGAL
  TERTUNDA
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum KategoriKondisi {
  UMUM
  ANAK_BALITA
  IBU_HAMIL
  PASCA_OPERASI
}

model ProfilKesehatan {
  id                  String           @id @map("profil_id")
  userId              String           @map("user_id")
  user                User             @relation(fields: [userId], references: [id])
  namaProfil          String           @map("nama_profil")
  jenisKelamin        JenisKelamin     @map("jenis_kelamin")
  umur                Int?
  beratBadan          Decimal?         @db.Decimal(5, 2) @map("berat_badan")
  tinggiBadan         Decimal?         @db.Decimal(5, 2) @map("tinggi_badan")
  kategoriKondisi     KategoriKondisi  @default(UMUM) @map("kategori_kondisi")
  usiaKehamilanMinggu Int?             @map("usia_kehamilan_minggu")
  anjuranKaloriDokter Int?             @map("anjuran_kalori_dokter")
  pantanganMedis      String?          @map("pantangan_medis")
  updatedAt           DateTime         @default(now()) @map("updated_at")

  riwayatAnalisis     RiwayatAnalisis[]

  @@map("profil_kesehatan")
}

model RiwayatAnalisis {
  id            String           @id @map("analisis_id")
  profilId      String           @map("profil_id")
  profil        ProfilKesehatan  @relation(fields: [profilId], references: [id])
  haz           Decimal          @db.Decimal(5, 2)
  whz           Decimal          @db.Decimal(5, 2)
  bmi           Decimal          @db.Decimal(5, 2)
  lila          Decimal?         @db.Decimal(5, 2)
  statusNutrisi String           @map("status_nutrisi")
  createdAt     DateTime         @default(now()) @map("created_at")

  mealPlan      MealPlan?

  @@map("riwayat_analisis")
}

model ProdukMakanan {
  id             String            @id @map("produk_id")
  namaProduk     String?           @map("nama_produk")
  kategori       String?           @map("kategori")
  gambar         String?           @map("gambar")
  harga          Decimal?          @db.Decimal(10, 2)
  deskripsi      String?
  nilaiGizi      Json?             @map("nilai_gizi")
  stok           Int?
  labelRisiko    String?           @map("label_risiko")

  cartItems      CartItem[]
  orderItems     OrderItem[]
  mealPlanProduk MealPlanProduk[]

  @@map("produk_makanan")
}

model Cart {
  id     String     @id @map("cart_id")
  userId String     @unique @map("user_id")
  user   User       @relation(fields: [userId], references: [id])
  items  CartItem[]

  @@map("cart")
}

model CartItem {
  id        String        @id @map("cart_item_id")
  cartId    String        @map("cart_id")
  cart      Cart          @relation(fields: [cartId], references: [id])
  produkId  String        @map("produk_id")
  produk    ProdukMakanan @relation(fields: [produkId], references: [id])
  kuantitas Int

  @@map("cart_item")
}

model Pesanan {
  id                String               @id @map("pesanan_id")
  userId            String               @map("user_id")
  user              User                 @relation(fields: [userId], references: [id])
  totalHarga        Decimal              @db.Decimal(12, 2) @map("total_harga")
  statusPesanan     StatusPesanan        @map("status_pesanan")
  createdAt         DateTime             @default(now()) @map("created_at")
  orderItems        OrderItem[]
  transaksiPembayaran TransaksiPembayaran?

  @@map("pesanan")
}

model OrderItem {
  id        String          @id @map("order_item_id")
  pesananId String          @map("pesanan_id")
  pesanan   Pesanan         @relation(fields: [pesananId], references: [id])
  produkId  String          @map("produk_id")
  produk    ProdukMakanan   @relation(fields: [produkId], references: [id])
  kuantitas Int
  harga     Decimal         @db.Decimal(10, 2)

  @@map("order_item")
}

model TransaksiPembayaran {
  id               String            @id @map("transaksi_id")
  pesananId        String            @unique @map("pesanan_id")
  pesanan          Pesanan           @relation(fields: [pesananId], references: [id])
  statusPembayaran StatusPembayaran  @map("status_pembayaran")
  metodePembayaran String?           @map("metode_pembayaran")
  createdAt        DateTime          @default(now()) @map("created_at")

  @@map("transaksi_pembayaran")
}

model MealPlan {
  id                 String           @id @map("mealplan_id")
  analisisId         String           @unique @map("analisis_id")
  riwayatAnalisis    RiwayatAnalisis @relation(fields: [analisisId], references: [id])
  detailRencanaMakan Json?            @map("detail_rencana_makan")
  produk             MealPlanProduk[]

  @@map("meal_plan")
}

model MealPlanProduk {
  id         String         @id
  mealplanId String         @map("mealplan_id")
  mealPlan   MealPlan       @relation(fields: [mealplanId], references: [id])
  produkId   String         @map("produk_id")
  produk     ProdukMakanan  @relation(fields: [produkId], references: [id])

  @@map("meal_plan_produk")
}
